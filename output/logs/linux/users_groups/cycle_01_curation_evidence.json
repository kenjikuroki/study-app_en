      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "The `id -n` option prints names instead of numeric IDs, but it must be used with `-u`, `-g`, or `-G`."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_users_groups_q_0009",
