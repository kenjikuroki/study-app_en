      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "The `id` command can print information about a named user or about the running process when no user is specified."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_users_groups_q_0002",
      "source_ir_id": "linux_users_groups_ir_0002",
      "source_document_path": "studyapp/input/source_documents/linux/users_groups/id-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "For `id`, a plain numeric-looking argument is always treated as a user ID even when a matching user name exists."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_users_groups_q_0003",
      "source_ir_id": "linux_users_groups_ir_0003",
      "source_document_path": "studyapp/input/source_documents/linux/users_groups/id-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "By default, `id` omits the real user ID and shows only the effective user ID."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_users_groups_q_0004",
      "source_ir_id": "linux_users_groups_ir_0004",
      "source_document_path": "studyapp/input/source_documents/linux/users_groups/id-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "By default, `id` never prints any group-related information."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_users_groups_q_0005",
      "source_ir_id": "linux_users_groups_ir_0005",
      "source_document_path": "studyapp/input/source_documents/linux/users_groups/id-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "By default, `id` prints the effective user ID only when it differs from the real user ID."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_users_groups_q_0006",
      "source_ir_id": "linux_users_groups_ir_0006",
      "source_document_path": "studyapp/input/source_documents/linux/users_groups/id-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "The `id -g` option prints only the user ID."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_users_groups_q_0007",
      "source_ir_id": "linux_users_groups_ir_0007",
      "source_document_path": "studyapp/input/source_documents/linux/users_groups/id-invocation.html",
      "reviewed_individually": true,
