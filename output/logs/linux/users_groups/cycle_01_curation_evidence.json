      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "The `id -G` option prints only the user ID and omits all group information."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_users_groups_q_0008",
      "source_ir_id": "linux_users_groups_ir_0008",
