    {
      "phase": "audit_question_candidate",
      "item_id": "linux_permissions_q_0001",
      "source_ir_id": "linux_permissions_ir_0001",
      "source_document_path": "studyapp/input/source_documents/linux/permissions/chmod-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "The `chmod` command changes the access permissions of named files."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_permissions_q_0002",
      "source_ir_id": "linux_permissions_ir_0002",
      "source_document_path": "studyapp/input/source_documents/linux/permissions/chmod-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "On most systems, `chmod` directly changes the permissions stored on a symbolic link itself."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_permissions_q_0003",
      "source_ir_id": "linux_permissions_ir_0003",
      "source_document_path": "studyapp/input/source_documents/linux/permissions/chmod-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "When a symbolic link is listed on the command line, `chmod` changes the permissions of the file it points to."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_permissions_q_0004",
      "source_ir_id": "linux_permissions_ir_0004",
      "source_document_path": "studyapp/input/source_documents/linux/permissions/chmod-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "During recursive directory traversals, `chmod` always changes the permissions of every symbolic link it encounters."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_permissions_q_0005",
      "source_ir_id": "linux_permissions_ir_0005",
      "source_document_path": "studyapp/input/source_documents/linux/permissions/chmod-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "Any process can change the mode bits of any file as long as the path exists."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_permissions_q_0006",
      "source_ir_id": "linux_permissions_ir_0006",
      "source_document_path": "studyapp/input/source_documents/linux/permissions/chmod-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "For command-line symlink arguments, `chmod --dereference` matches the default behavior."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_permissions_q_0007",
      "source_ir_id": "linux_permissions_ir_0007",
      "source_document_path": "studyapp/input/source_documents/linux/permissions/chmod-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "The `chmod --reference` option copies the mode from a reference file."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_permissions_q_0008",
      "source_ir_id": "linux_permissions_ir_0008",
      "source_document_path": "studyapp/input/source_documents/linux/permissions/chmod-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "The `chmod --recursive` option changes only the top directory and never touches its contents."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_permissions_q_0009",
      "source_ir_id": "linux_permissions_ir_0009",
      "source_document_path": "studyapp/input/source_documents/linux/permissions/chmod-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "With recursive `chmod`, `-H` can traverse a command-line argument that is a symlink to a directory."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_permissions_q_0010",
      "source_ir_id": "linux_permissions_ir_0010",
      "source_document_path": "studyapp/input/source_documents/linux/permissions/chmod-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "With recursive `chmod`, `-L` refuses to traverse symlinks to directories that are encountered."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_permissions_q_0011",
      "source_ir_id": "linux_permissions_ir_0011",
      "source_document_path": "studyapp/input/source_documents/linux/permissions/chmod-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "With recursive `chmod`, the `-P` option means symbolic links are not traversed."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_permissions_q_0012",
      "source_ir_id": "linux_permissions_ir_0012",
      "source_document_path": "studyapp/input/source_documents/linux/permissions/chmod-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "The `chmod --preserve-root` option has no effect when a recursive `chmod` operation targets `/`."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_permissions_q_0013",
      "source_ir_id": "linux_permissions_ir_0013",
      "source_document_path": "studyapp/input/source_documents/linux/permissions/chown-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "The `chown` command can change user ownership, group ownership, or both."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_permissions_q_0014",
      "source_ir_id": "linux_permissions_ir_0014",
      "source_document_path": "studyapp/input/source_documents/linux/permissions/chown-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "If `chown` is given `owner:group`, it changes only the owner and leaves the group unchanged."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_permissions_q_0015",
      "source_ir_id": "linux_permissions_ir_0015",
      "source_document_path": "studyapp/input/source_documents/linux/permissions/chown-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "If `chown` is given `owner:` with no group name, the file's group is changed to that owner's login group."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_permissions_q_0016",
      "source_ir_id": "linux_permissions_ir_0016",
      "source_document_path": "studyapp/input/source_documents/linux/permissions/chown-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "If `chown` is given `:group` with no owner, it changes only the group and acts like `chgrp`."
    },
    {
