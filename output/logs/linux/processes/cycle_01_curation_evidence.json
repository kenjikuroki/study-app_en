      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "The `timeout` command runs a command and kills it if it is still running after the specified time interval."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_processes_q_0002",
      "source_ir_id": "linux_processes_ir_0002",
      "source_document_path": "studyapp/input/source_documents/linux/processes/timeout-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "The command managed by `timeout` may be a shell special built-in utility."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_processes_q_0003",
      "source_ir_id": "linux_processes_ir_0003",
      "source_document_path": "studyapp/input/source_documents/linux/processes/timeout-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "The `timeout --foreground` option avoids creating a separate background program group so the command can use the foreground TTY normally."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_processes_q_0004",
      "source_ir_id": "linux_processes_ir_0004",
      "source_document_path": "studyapp/input/source_documents/linux/processes/timeout-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "In `timeout --foreground` mode, all children of the managed command are still guaranteed to be timed out."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_processes_q_0005",
      "source_ir_id": "linux_processes_ir_0005",
      "source_document_path": "studyapp/input/source_documents/linux/processes/timeout-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "The `timeout --kill-after` option ensures the monitored command is also sent a KILL signal."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_processes_q_0006",
      "source_ir_id": "linux_processes_ir_0006",
      "source_document_path": "studyapp/input/source_documents/linux/processes/timeout-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "For `timeout --kill-after`, the extra duration is measured from when the command starts, not from when the first timeout signal is sent."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_processes_q_0007",
      "source_ir_id": "linux_processes_ir_0007",
      "source_document_path": "studyapp/input/source_documents/linux/processes/timeout-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "The `timeout --kill-after` option has no effect if the main timeout duration or the kill-after duration is 0."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_processes_q_0008",
      "source_ir_id": "linux_processes_ir_0008",
      "source_document_path": "studyapp/input/source_documents/linux/processes/timeout-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "With `timeout --preserve-status`, a timeout still always returns a fixed timeout status instead of the managed command's status."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_processes_q_0009",
      "source_ir_id": "linux_processes_ir_0009",
      "source_document_path": "studyapp/input/source_documents/linux/processes/timeout-invocation.html",
      "reviewed_individually": true,
      "source_checked": true,
      "source_ir_checked": true,
      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "The `timeout --signal` option can send a chosen signal instead of the default TERM signal."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_processes_q_0010",
      "source_ir_id": "linux_processes_ir_0010",
      "source_document_path": "studyapp/input/source_documents/linux/processes/timeout-invocation.html",
      "reviewed_individually": true,
