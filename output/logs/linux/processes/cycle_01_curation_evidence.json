      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "The `timeout` command accepts duration suffixes for seconds, minutes, hours, and days."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_processes_q_0012",
      "source_ir_id": "linux_processes_ir_0012",
      "source_document_path": "studyapp/input/source_documents/linux/processes/timeout-invocation.html",
