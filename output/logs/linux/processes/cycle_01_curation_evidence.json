      "decision": "approved",
      "reason": "Question item was loaded from the structured curated profile and reviewed individually.",
      "question_text": "In `timeout`, a duration of 0 forces the associated timeout to expire immediately."
    },
    {
      "phase": "audit_question_candidate",
      "item_id": "linux_processes_q_0013",
