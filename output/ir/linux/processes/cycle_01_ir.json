      "id": "linux_processes_ir_0001",
      "topic": "timeout purpose",
      "category": "processes",
      "fact_type": "command",
      "statement": "The timeout command runs the given command and kills it if it is still running after the specified time interval.",
      "conditions": [],
      "examples": [
        "timeout 5 sleep 10"
      ],
      "source": "GNU Coreutils 9.11 manual",
      "source_document_path": "studyapp/input/source_documents/linux/processes/timeout-invocation.html",
      "source_url": "https://www.gnu.org/software/coreutils/manual/html_node/timeout-invocation.html",
      "source_title": "GNU Coreutils manual",
      "source_version": "9.11",
      "source_last_checked": "2026-06-06",
      "source_section": "23.6 timeout: Run a command with a time limit",
      "source_quote_or_summary": "timeout runs a command with a time limit and kills it if it overruns.",
      "confidence": "high",
      "question_potential": "high",
      "notes": ""
    },
    {
      "id": "linux_processes_ir_0002",
      "topic": "timeout built-in restriction",
      "category": "processes",
      "fact_type": "limitation",
      "statement": "The command run by timeout must not be a special built-in utility.",
