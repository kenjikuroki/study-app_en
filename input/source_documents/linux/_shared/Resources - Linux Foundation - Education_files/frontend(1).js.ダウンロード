(function () {
  'use strict';

  function parseConfig(node) {
    var raw = node.getAttribute('data-conf');
    if (!raw) {
      return null;
    }

    try {
      return JSON.parse(raw);
    } catch (e) {
      return null;
    }
  }

  function pad(value) {
    return value < 10 ? '0' + value : String(value);
  }

  function diffParts(expiryMs) {
    var nowMs = Date.now();
    var totalRaw = Math.max(0, (expiryMs - nowMs) / 1000);
    var remain = totalRaw;

    var days = Math.floor(remain / 86400);
    remain -= days * 86400;

    var hours = Math.floor(remain / 3600);
    remain -= hours * 3600;

    var minutes = Math.floor(remain / 60);
    var seconds = Math.floor(remain - minutes * 60);

    return {
      total: Math.max(0, Math.floor(totalRaw)),
      totalRaw: totalRaw,
      days: days,
      hours: hours,
      minutes: minutes,
      seconds: seconds
    };
  }

  function toFiniteNumber(value, fallback) {
    var parsed = Number(value);
    return Number.isFinite(parsed) ? parsed : fallback;
  }

  // Legacy plugin used small fractional values, so map them to visible SVG pixel widths.
  function normalizeStrokeWidth(value, fallback) {
    var raw = toFiniteNumber(value, fallback);
    return Math.max(0.5, Math.min(12, raw * 3));
  }

  function smoothProgressValue(parts, key) {
    var totalRaw = parts.totalRaw;

    if (key === 'days') {
      return totalRaw / 86400;
    }
    if (key === 'hours') {
      return (totalRaw % 86400) / 3600;
    }
    if (key === 'minutes') {
      return (totalRaw % 3600) / 60;
    }
    return totalRaw % 60;
  }

  function createUnitElement(label, color, circleWidthPx, trackWidthPx, trackColor, smoothAnimation) {
    var unit = document.createElement('span');
    unit.className = 'lf-timer-unit';
    if (color) {
      unit.style.setProperty('--lf-timer-accent', color);
    }

    // Create SVG circles: background track + foreground progress.
    var svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('viewBox', '0 0 56 56');

    var trackCircle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    trackCircle.setAttribute('cx', '28');
    trackCircle.setAttribute('cy', '28');
    trackCircle.setAttribute('r', '24');
    trackCircle.style.stroke = trackColor || '#313332';
    trackCircle.style.strokeWidth = String(trackWidthPx);
    trackCircle.style.opacity = '0.45';

    var circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    circle.setAttribute('cx', '28');
    circle.setAttribute('cy', '28');
    circle.setAttribute('r', '24');
    circle.style.strokeWidth = String(circleWidthPx);
    if (smoothAnimation) {
      circle.style.transition = 'stroke-dashoffset 0.24s linear';
    } else {
      circle.style.transition = 'none';
    }

    svg.appendChild(trackCircle);
    svg.appendChild(circle);
    unit.appendChild(svg);
    unit._circle = circle;

    // Create content wrapper for text.
    var content = document.createElement('div');
    content.className = 'lf-timer-content';

    var labelEl = document.createElement('small');
    labelEl.className = 'lf-timer-label';
    labelEl.textContent = label;

    var valueEl = document.createElement('strong');
    valueEl.className = 'lf-timer-value';

    content.appendChild(labelEl);
    content.appendChild(valueEl);
    unit.appendChild(content);
    unit._valueEl = valueEl;

    return unit;
  }

  function updateUnitValue(unit, value, progressValue, maxValue) {
    // Update displayed value
    unit._valueEl.textContent = pad(value);

    // Update stroke-dashoffset
    var remaining = maxValue > 0 ? Math.max(0, Math.min(1, progressValue / maxValue)) : 0;
    var circumference = 150.796;
    var dashoffset = circumference * (1 - remaining);
    unit._circle.style.strokeDashoffset = String(-dashoffset);
  }

  function mountTimer(node) {
    var conf = parseConfig(node);
    if (!conf || !conf.expiry_date) {
      return;
    }

    var expiryMs = Date.parse(conf.expiry_date);
    if (!expiryMs) {
      return;
    }

    var animationMode = String(conf.timercircle_animation || 'smooth');
    var smoothAnimation = animationMode === 'smooth';
    var circleWidthPx = normalizeStrokeWidth(conf.timercircle_width, 0.1);
    var trackWidthPx = normalizeStrokeWidth(conf.timer_bg_width, 1.2);
    var trackColor = conf.timer_bgclr || '#313332';

    node.classList.add('lf-timer-ready');

    // Cache unit elements to avoid recreating DOM every second
    var units = [];

    if (Number(conf.is_days) === 1) {
      units.push({
        key: 'days',
        element: createUnitElement(conf.day_text || 'Days', conf.timer_day_bgclr, circleWidthPx, trackWidthPx, trackColor, smoothAnimation),
        maxValue: 365,
        getPart: function (parts) { return parts.days; }
      });
    }
    if (Number(conf.is_hours) === 1) {
      units.push({
        key: 'hours',
        element: createUnitElement(conf.hour_text || 'Hours', conf.timer_hour_bgclr, circleWidthPx, trackWidthPx, trackColor, smoothAnimation),
        maxValue: 24,
        getPart: function (parts) { return parts.hours; }
      });
    }
    if (Number(conf.is_minutes) === 1) {
      units.push({
        key: 'minutes',
        element: createUnitElement(conf.minute_text || 'Minutes', conf.timer_minute_bgclr, circleWidthPx, trackWidthPx, trackColor, smoothAnimation),
        maxValue: 60,
        getPart: function (parts) { return parts.minutes; }
      });
    }
    if (Number(conf.is_seconds) === 1) {
      units.push({
        key: 'seconds',
        element: createUnitElement(conf.second_text || 'Seconds', conf.timer_second_bgclr, circleWidthPx, trackWidthPx, trackColor, smoothAnimation),
        maxValue: 60,
        getPart: function (parts) { return parts.seconds; }
      });
    }

    // Append all units once
    for (var i = 0; i < units.length; i += 1) {
      node.appendChild(units[i].element);
    }

    var intervalId = 0;

    function paint() {
      var parts = diffParts(expiryMs);

      if (parts.total <= 0) {
        var wrap = node.closest('.lf-timer-wrap');
        if (wrap) {
          wrap.style.display = 'none';
        }
        if (intervalId) {
          window.clearInterval(intervalId);
        }
        return;
      }

      // Update only values and stroke-dashoffset, not DOM structure
      for (var i = 0; i < units.length; i += 1) {
        var unitData = units[i];
        var value = unitData.getPart(parts);
        var progressValue = smoothAnimation ? smoothProgressValue(parts, unitData.key) : value;
        updateUnitValue(unitData.element, value, progressValue, unitData.maxValue);
      }
    }

    paint();
    intervalId = window.setInterval(paint, smoothAnimation ? 250 : 1000);
    
    // Store interval ID on node for cleanup if needed
    if (!node._intervals) {
      node._intervals = [];
    }
    node._intervals.push(intervalId);
  }

  function init() {
    var nodes = document.querySelectorAll('.lf-timer-circle[data-conf]');
    for (var i = 0; i < nodes.length; i += 1) {
      mountTimer(nodes[i]);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
